generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  type      String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model UploadHistory {
  id         String   @id @default(uuid())
  fileName   String
  rowCount   Int      @default(0)
  status     String
  uploadedAt DateTime @default(now())
}