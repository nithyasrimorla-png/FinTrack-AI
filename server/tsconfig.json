{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true
  },

  "include": [
    "src/**/*.ts",
    "prisma.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "generated"
  ]
}